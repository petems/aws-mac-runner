# AWS Configuration
aws_region        = "us-east-2"
availability_zone = "us-east-2a"
environment       = "dev"
name_prefix       = "mac-runner"

# Instance Configuration
# Options: mac2.metal (M1), mac2-m2.metal (M2), mac2-m2pro.metal (M2 Pro)
instance_type  = "mac2.metal"
macos_version  = "15"

# EBS Volume - tuned for CI/CD workloads
root_volume_size       = 200
root_volume_iops       = 10000
root_volume_throughput = 400

# Network
vpc_cidr           = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"

# SSH access - leave empty for SSM-only (recommended)
# ssh_allowed_cidrs = ["203.0.113.0/32"]
ssh_allowed_cidrs = []

# GitHub Runner Configuration
# Generate token: gh api -X POST repos/{owner}/{repo}/actions/runners/registration-token --jq '.token'
github_runner_token  = "REPLACE_ME"
github_runner_url    = "https://github.com/your-org/your-repo"
github_runner_name   = "mac-runner"
github_runner_labels = "self-hosted,macOS,ARM64,apple-silicon"
github_runner_group  = "default"

# SSM Session Logging (optional)
enable_ssm_logging = false
